#!/usr/bin/env bash

if [[ -n "$1" ]]; then
    SESSION="$1"
else
    if [[ -n "$TMUX" ]]; then
        SESSION=$(tmux display-message -p '#S')
    else
        echo "Usage: tmux-kill <session>" >&2
        exit 1
    fi
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No session: $SESSION" >&2
    exit 1
fi

tmux kill-session -t "$SESSION"
