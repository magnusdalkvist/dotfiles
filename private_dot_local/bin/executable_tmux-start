#!/usr/bin/env bash

if [[ -n "$TMUX" ]]; then
    BASE="${1:-main}"
    SESSION="$BASE"
    i=2
    while tmux has-session -t "$SESSION" 2>/dev/null; do
        SESSION="${BASE}-${i}"
        ((i++))
    done
else
    SESSION="${1:-main}"
    if tmux has-session -t "$SESSION" 2>/dev/null; then
        tmux attach-session -t "$SESSION"
        exit
    fi
fi

tmux new-session -d -s "$SESSION"
# Capture stable pane ids — tmux renumbers pane *indices* after each split,
# so we track %ids instead of 0.0/0.2/etc.
LEFT=$(tmux display-message -p -t "$SESSION:0.0" '#{pane_id}')
# Right column (50%): terminal
RIGHT=$(tmux split-window -h -p 50 -t "$LEFT" -P -F '#{pane_id}')
# Left column: clock (top 25%), then split the lower 75% into overview + claude
MID=$(tmux split-window -v -p 75 -t "$LEFT" -P -F '#{pane_id}')
# overview = 1/3 of that 75% (≈25% total), claude = 2/3 (≈50% total)
CLAUDE=$(tmux split-window -v -p 67 -t "$MID" -P -F '#{pane_id}')

tmux send-keys -t "$LEFT" "tmux-clock" Enter
tmux send-keys -t "$MID" "tmux-session-overview" Enter
tmux send-keys -t "$CLAUDE" "claude" Enter

tmux select-pane -t "$CLAUDE"

if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$SESSION"
else
    tmux attach-session -t "$SESSION"
fi
