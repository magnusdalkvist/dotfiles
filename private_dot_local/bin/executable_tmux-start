#!/usr/bin/env bash

# Parse args: --ssh opens the claude + terminal panes on a remote dev box
# (configured in ~/.config/tmux-start.conf); any other arg is the session name.
SSH_MODE=0
BASE=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --ssh|-s) SSH_MODE=1 ;;
        *)        BASE="$1" ;;
    esac
    shift
done

REMOTE_CLAUDE=""
REMOTE_TERM=""

if (( SSH_MODE )); then
    if (( BASH_VERSINFO[0] < 4 )); then
        echo "tmux-start --ssh requires bash 4+. On macOS: brew install bash" >&2
        exit 1
    fi
    command -v fzf &>/dev/null || { echo "tmux-start --ssh requires fzf" >&2; exit 1; }

    CONF="${XDG_CONFIG_HOME:-$HOME/.config}/tmux-start.conf"
    if [[ ! -f "$CONF" ]]; then
        echo "No remote config at $CONF" >&2
        echo "Create it with:" >&2
        echo "  host=your-ssh-host   # alias from ~/.ssh/config, or user@host" >&2
        echo "  root=~/code          # remote dir whose subfolders are your repos" >&2
        exit 1
    fi

    trim() { local s="$1"; s="${s#"${s%%[![:space:]]*}"}"; s="${s%"${s##*[![:space:]]}"}"; printf '%s' "$s"; }

    HOST="" ROOT=""
    while IFS='=' read -r key val; do
        key="$(trim "$key")"
        [[ -z "$key" || "$key" == \#* ]] && continue
        val="$(trim "$val")"
        case "$key" in
            host) HOST="$val" ;;
            root) ROOT="$val" ;;
        esac
    done < "$CONF"

    [[ -z "$HOST" ]] && { echo "No 'host=' line in $CONF" >&2; exit 1; }
    ROOT="${ROOT:-~/code}"

    # Share one connection across the listing + both panes (no repeated auth).
    SSH_CTL="$HOME/.ssh/cm-tmux-start-%r@%h:%p"
    SSH_OPTS=(-o ControlMaster=auto -o "ControlPath=$SSH_CTL" -o ControlPersist=60)

    # ~ and * expand on the remote; trailing slash stripped for clean basenames.
    mapfile -t REPOS < <(ssh "${SSH_OPTS[@]}" "$HOST" "ls -1d $ROOT/*/ 2>/dev/null" | sed 's#/*$##')
    if (( ${#REPOS[@]} == 0 )); then
        echo "No directories found in $ROOT on $HOST" >&2
        exit 1
    fi

    REPO=$(printf '%s\n' "${REPOS[@]}" | fzf --prompt="$HOST repo> " --delimiter=/ --with-nth=-1)
    [[ -z "$REPO" ]] && { echo "No selection." >&2; exit 1; }

    NAME="$(basename "$REPO")"
    BASE="${BASE:-${NAME//[.:]/-}}"

    # Build the commands typed into each remote pane. %q escapes for the local
    # shell so $SHELL and the path survive intact to the remote shell.
    build_ssh() {
        printf 'ssh -t -o ControlMaster=auto -o ControlPath=%q -o ControlPersist=60 %q %q' \
            "$SSH_CTL" "$HOST" "cd \"$REPO\" && $1"
    }
    REMOTE_CLAUDE="$(build_ssh claude)"
    REMOTE_TERM="$(build_ssh 'exec $SHELL -l')"
fi

BASE="${BASE:-main}"

if [[ -n "$TMUX" ]]; then
    SESSION="$BASE"
    i=2
    while tmux has-session -t "$SESSION" 2>/dev/null; do
        SESSION="${BASE}-${i}"
        ((i++))
    done
else
    SESSION="$BASE"
    if tmux has-session -t "$SESSION" 2>/dev/null; then
        tmux attach-session -t "$SESSION"
        exit
    fi
fi

# Build the session at the real terminal size so attaching doesn't trigger a
# proportional rescale that would stretch the absolute pane heights back out.
if [[ -n "$TMUX" ]]; then
    COLS=$(tmux display-message -p '#{client_width}')
    ROWS=$(tmux display-message -p '#{client_height}')
else
    COLS=$(tput cols)
    ROWS=$(tput lines)
fi
tmux new-session -d -s "$SESSION" -x "${COLS:-200}" -y "${ROWS:-50}"
tmux set-option -t "$SESSION" default-shell "${SHELL:-/bin/sh}"
# Capture stable pane ids — tmux renumbers pane *indices* after each split,
# so we track %ids instead of 0.0/0.2/etc.
LEFT_TOP=$(tmux display-message -p -t "$SESSION:0.0" '#{pane_id}')
# Right column (50%)
RIGHT_TOP=$(tmux split-window -h -p 50 -t "$LEFT_TOP" -P -F '#{pane_id}')
# Left column: overview (top), claude (bottom)
LEFT_BOT=$(tmux split-window -v -p 80 -t "$LEFT_TOP" -P -F '#{pane_id}')
# Right column: clock (top), terminal (bottom)
RIGHT_BOT=$(tmux split-window -v -p 80 -t "$RIGHT_TOP" -P -F '#{pane_id}')

# Pin the overview and clock panes to exactly 7 lines tall.
tmux resize-pane -t "$LEFT_TOP" -y 7
tmux resize-pane -t "$RIGHT_TOP" -y 7

# Label these panes so the border shows their purpose, not "bash".
tmux set -p -t "$LEFT_TOP" @label "sessions"
tmux set -p -t "$RIGHT_TOP" @label "clock"

# Overview and clock are local TUIs (they drive the local tmux server), so they
# stay local even in --ssh mode; only claude + the terminal go to the dev box.
tmux send-keys -t "$LEFT_TOP" "tmux-session-overview" Enter
tmux send-keys -t "$RIGHT_TOP" "tmux-clock" Enter
if (( SSH_MODE )); then
    tmux send-keys -t "$LEFT_BOT" "$REMOTE_CLAUDE" Enter
    tmux send-keys -t "$RIGHT_BOT" "$REMOTE_TERM" Enter
else
    tmux send-keys -t "$LEFT_BOT" "claude" Enter
    # RIGHT_BOT stays a plain terminal
fi

tmux select-pane -t "$LEFT_BOT"

if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$SESSION"
else
    tmux attach-session -t "$SESSION"
fi
